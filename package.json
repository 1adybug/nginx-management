    "private": true,
    "scripts": {
        "dev": "sdnext dev next dev --turbopack --hostname 0.0.0.0",
        "build": "sdnext build next build",
        "start": "next start",
        "auth:secret": "node -e \"console.log(require('node:crypto').randomBytes(32).toString('hex'))\"",
